# =============================================================================
# AREC CRM — Environment Variables
# =============================================================================
# Copy this file to app/.env and fill in your values.
#   cp app/.env.example app/.env
#
# All secrets are stored in 1Password vault "AREC Infrastructure"
# and in Azure Key Vault "kv-arec-crm" for production.
# =============================================================================


# --- Database ----------------------------------------------------------------
# Local dev: point to local Postgres or Azure Postgres directly
# Production: pulled from Azure Key Vault secret "DATABASE-URL"
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://localhost/arec_crm


# --- Anthropic (Claude API) -------------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
# Production: Azure Key Vault secret "ANTHROPIC-API-KEY"
ANTHROPIC_API_KEY=sk-ant-...


# --- Azure Entra ID (SSO) ---------------------------------------------------
# Get from: Azure Portal > App Registrations > AREC CRM app
# Client ID is not sensitive (public identifier)
# Client Secret is sensitive — production uses Key Vault secret "ENTRA-CLIENT-SECRET"
AZURE_CLIENT_ID=94270ca6-e1e1-4f0f-bdd0-f8df2cbb3750
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_TENANT_ID=ebd42ab2-7f1c-4d40-8b44-f5ecc51d2659
AZURE_AUTHORITY=https://login.microsoftonline.com/ebd42ab2-7f1c-4d40-8b44-f5ecc51d2659
AZURE_REDIRECT_URI=http://localhost:8000/.auth/login/aad/callback


# --- Local Dev Auth Bypass ---------------------------------------------------
# Set this to skip OAuth during local development.
# The user will be auto-provisioned on first request.
DEV_USER=oscar@avilacapllc.com


# --- Flask -------------------------------------------------------------------
# Production: set FLASK_SECRET_KEY to a random 64-char hex string
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-secret-key-change-in-production
FLASK_DEBUG=false
DASHBOARD_PORT=8000


# --- Microsoft Graph API (Email Scanning) ------------------------------------
# User ID for Graph API calls. Use "me" for current user, or a specific UUID.
# Only needed if running email polling locally.
MS_USER_ID=me


# --- CRM Shared Mailbox -----------------------------------------------------
# Email address for the shared CRM inbox (used by drain_inbox.py)
AI_INBOX_EMAIL=crm@avilacapllc.com
