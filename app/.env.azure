# Azure Environment Variables for AREC CRM
# Copy this to .env and fill in actual values for local testing
# In Azure App Service, these are set via App Settings (which pull from Key Vault)

# Database (actual values from Azure Portal - see DEPLOYMENT.md)
DATABASE_URL=postgresql://arecadmin:<PASSWORD>@arec-crm-db.postgres.database.azure.com:5432/arec_crm?sslmode=require

# Anthropic API (stored in Azure Key Vault: ANTHROPIC-API-KEY)
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# Microsoft Entra ID SSO (values from SPEC § 9)
AZURE_CLIENT_ID=94270ca6-e1e1-4f0f-bdd0-f8df2cbb3750
AZURE_CLIENT_SECRET=<stored_in_key_vault_ENTRA-CLIENT-SECRET>
AZURE_TENANT_ID=ebd42ab2-7f1c-4d40-8b44-f5ecc51d2659
AZURE_AUTHORITY=https://login.microsoftonline.com/ebd42ab2-7f1c-4d40-8b44-f5ecc51d2659
AZURE_REDIRECT_URI=https://arec-crm-app.azurewebsites.net/.auth/login/aad/callback

# Flask
FLASK_SECRET_KEY=<generate_random_secret_key_with_python_secrets_token_hex_32>
FLASK_DEBUG=false
DASHBOARD_PORT=8000

# Azure Key Vault (for production - app pulls secrets automatically)
AZURE_KEY_VAULT_NAME=kv-arec-crm
